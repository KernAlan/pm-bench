    { "id": 16, "type": "jira", "ticket": "PLAT-350", "action": "status_change", "from": "In Progress", "to": "In Review", "user": "Marcus Washington", "content": "", "label": "queue", "reasoning": "Critical path ticket moving forward — good signal but no action needed" },
    { "id": 17, "type": "slack", "channel": "#platform-eng", "user": "Nina Kowalski", "content": "Sarah — can you send me the updated risk assessment for the billing migration before our Wednesday 1:1?", "label": "act-now", "reasoning": "Director asking for deliverable from Sarah who is on PTO. Needs intervention." },
