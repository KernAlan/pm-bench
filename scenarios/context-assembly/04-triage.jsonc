    { "id": 31, "type": "slack", "channel": "#platform-eng", "user": "Rachel Torres", "content": "Staging 503s were caused by the migration script running during a health check window. Fixed — added a pre-check step. Staging is stable now.", "label": "queue", "reasoning": "Resolution of earlier issue. Good to track." },
