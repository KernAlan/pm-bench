    { "id": 34, "type": "slack", "channel": "#platform-eng", "user": "bot:github", "content": "PR #360 opened: 'Update CI cache configuration' by Rachel Torres — 2 files changed", "label": "ignore", "reasoning": "Infrastructure improvement, not critical path" },
