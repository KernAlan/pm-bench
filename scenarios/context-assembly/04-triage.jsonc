    { "id": 14, "type": "slack", "channel": "#platform-design", "user": "Lisa Park", "content": "Updated billing dashboard wireframes based on the API contract. Link: [notion]", "label": "queue", "reasoning": "Relevant to billing migration but not urgent" },
