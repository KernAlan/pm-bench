    { "id": 26, "type": "slack", "channel": "#platform-eng", "user": "Dev Okonkwo", "content": "I just realized the billing migration runbook doesn't cover the grandfathered plans rollback scenario. Adding it now.", "label": "queue", "reasoning": "Good proactive work on risk mitigation, worth tracking" },
