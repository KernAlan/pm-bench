  ],

  "evaluation": {
    "metrics": {
      "overallAgreement": { "target": 0.85, "description": "Percentage of events where model matches human label" },
      "falseNegativeActNow": { "target": 0.05, "description": "Percentage of 'act-now' events classified as ignore/queue (CRITICAL — missing urgent events)" },
      "falsePositiveActNow": { "target": 0.20, "description": "Percentage of non-act-now events classified as act-now (some over-triggering is acceptable)" }
    },
    "killCondition": "<85% overall agreement, or >5% missed urgent events."
  }
}
