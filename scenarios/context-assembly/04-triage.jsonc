    { "id": 21, "type": "jira", "ticket": "PLAT-355", "action": "created", "user": "Priya Patel", "content": "Security: Update TLS certificates before March 1 expiry", "label": "queue", "reasoning": "Not billing-related but has a deadline. Should track." },
    { "id": 22, "type": "slack", "channel": "#platform-eng", "user": "Sarah Chen", "content": "Back online briefly — Alex, the compound discount type in discount_overrides means the discount stacks year-over-year. Check the grandfathered_plans doc. Sorry for the delay.", "label": "queue", "reasoning": "Sarah answering from PTO — unblocks Alex. Good signal but also concerning she felt she had to respond on PTO." },
    { "id": 23, "type": "slack", "channel": "#platform-eng", "user": "bot:github", "content": "PR #359 opened: 'Add billing period boundary tests' by Alex Kim — 12 files changed", "label": "queue", "reasoning": "Related to critical path, but routine PR opening" },
