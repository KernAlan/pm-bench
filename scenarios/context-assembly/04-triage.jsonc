  // Scenario 4: Triage Classification
  // Hypothesis: Cheap model + intent summary can classify events accurately.
  // Kill condition: <85% overall agreement, or >5% missed urgent events.

  "id": "04-triage",
  "name": "Triage Classification",
  "hypothesis": "A cheap model with a compressed intent summary can classify events with >85% agreement, <5% missed urgent, <20% false urgent.",

  "intentSummary": "Critical: Billing migration to unified schema. Deadline March 15. API team (Marcus, Alex) building endpoints. Sarah is single point of failure on legacy schema — she's on PTO today. Alex is blocked on a legacy schema question. Staging is ready. Key stakeholders: Jordan (VP Sales) asking about timeline for enterprise customer CloudFirst. Background: Q2 planning — stable, nudge don't push.",

  "events": [
    { "id": 1,  "type": "slack", "channel": "#platform-eng", "user": "bot:github", "content": "PR #358 merged: 'Fix typo in README' by Dev Okonkwo", "label": "ignore", "reasoning": "Trivial PR, not on critical path" },
    { "id": 2,  "type": "slack", "channel": "#platform-eng", "user": "Marcus Washington", "content": "PLAT-350 PR is up for review. Billing API create subscription endpoint.", "label": "act-now", "reasoning": "Critical path ticket, needs review to unblock next steps" },
    { "id": 3,  "type": "slack", "channel": "#random", "user": "Dev Okonkwo", "content": "Anyone want to grab lunch at the new Thai place?", "label": "ignore", "reasoning": "Social, not work-related" },
    { "id": 4,  "type": "slack", "channel": "#platform-eng", "user": "Alex Kim", "content": "Still blocked on the discount_overrides question from this morning. Anyone?", "label": "act-now", "reasoning": "Engineer blocked on critical path work, knowledge silo risk" },
    { "id": 5,  "type": "jira", "ticket": "PLAT-351", "action": "comment", "user": "Alex Kim", "content": "Status: blocked. Waiting for clarification on legacy schema discount_overrides table.", "label": "act-now", "reasoning": "Critical path ticket explicitly blocked" },
    { "id": 6,  "type": "slack", "channel": "#platform-eng", "user": "bot:ci", "content": "Build #4521 passed: main branch", "label": "ignore", "reasoning": "Routine CI success notification" },
    { "id": 7,  "type": "slack", "channel": "#platform-eng", "user": "bot:ci", "content": "Build #4522 FAILED: billing-api branch. Error: test_proration_compound_discount", "label": "act-now", "reasoning": "Build failure on billing-related branch, critical path" },
    { "id": 8,  "type": "slack", "channel": "#platform-standup", "user": "Rachel Torres", "content": "Working on CI cache optimization today. Nothing blocking.", "label": "ignore", "reasoning": "Routine standup update, not critical path" },
    { "id": 9,  "type": "slack", "channel": "#platform-eng", "user": "Jordan Rivera", "content": "Hey team — CloudFirst is asking again about the March timeline. Can someone give me a quick update?", "label": "act-now", "reasoning": "VP Sales asking about critical path timeline, stakeholder management needed" },
    { "id": 10, "type": "slack", "channel": "#platform-eng", "user": "Priya Patel", "content": "Reviewing Marcus's billing API PR now. Will have comments by EOD.", "label": "queue", "reasoning": "Relevant to critical path but no action needed — review is happening" },
    { "id": 11, "type": "jira", "ticket": "PLAT-342", "action": "status_change", "from": "In Progress", "to": "Done", "user": "Priya Patel", "content": "API key rotation completed.", "label": "ignore", "reasoning": "Completed ticket not on critical path" },
    { "id": 12, "type": "slack", "channel": "#platform-eng", "user": "Alex Kim", "content": "Marcus — should I use the standard retry middleware or the billing-specific one?", "label": "queue", "reasoning": "Question for Marcus, not blocked yet, just asking" },
